<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><!-- TPL:PAGE_TITLE --></title>
  <style>
    :root {
      --ivory:    #141413;
      --slate:    #FAF9F5;
      --clay:     #E08B6E;
      --oat:      #2A2520;
      --olive:    #9CB07A;
      --gray-150: #1F1E1C;
      --gray-300: #2D2C2A;
      --gray-500: #87867F;
      --gray-700: #C4C2BC;
      --white:    #1A1918;

      --serif: ui-serif, Georgia, 'Times New Roman', serif;
      --sans:  system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      --mono:  ui-monospace, 'SF Mono', Menlo, Monaco, monospace;
    }
    html { color-scheme: dark; }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--sans);
      background: var(--ivory);
      color: var(--gray-700);
      line-height: 1.6;
      padding: 56px 32px 120px;
      -webkit-font-smoothing: antialiased;
    }

    .page { max-width: 1040px; margin: 0 auto; }

    header.page-head { margin-bottom: 40px; max-width: 820px; }
    .eyebrow {
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--gray-500);
      margin-bottom: 12px;
      font-family: var(--mono);
    }
    h1 {
      font-family: var(--serif);
      font-weight: 500;
      font-size: 36px;
      line-height: 1.15;
      color: var(--slate);
      margin-bottom: 10px;
      letter-spacing: -0.01em;
    }
    .doc-meta {
      font-family: var(--mono);
      font-size: 12.5px;
      color: var(--gray-500);
    }

    .layout {
      display: grid;
      grid-template-columns: 1fr 240px;
      gap: 48px;
      align-items: start;
    }
    @media (max-width: 900px) { .layout { grid-template-columns: 1fr; } .toc { display: none; } }

    .toc {
      position: sticky;
      top: 32px;
      border-left: 1.5px solid var(--gray-300);
      padding-left: 18px;
      font-size: 13px;
    }
    .toc .t-head {
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--gray-500);
      margin-bottom: 10px;
    }
    .toc a { display: block; color: var(--gray-700); text-decoration: none; padding: 4px 0; }
    .toc a:hover { color: var(--clay); }
    .toc .sub { padding-left: 12px; color: var(--gray-500); font-size: 12.5px; }

    .tldr {
      background: var(--white);
      border: 1.5px solid var(--gray-300);
      border-left: 4px solid var(--clay);
      border-radius: 12px;
      padding: 20px 24px;
      margin-bottom: 40px;
      max-width: 760px;
    }
    .tldr .k {
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--gray-500);
      margin-bottom: 8px;
    }
    .tldr p { font-size: 15px; color: var(--slate); }

    article.content { max-width: 760px; }
    article.content h2 {
      font-family: var(--serif);
      font-weight: 500;
      font-size: 25px;
      color: var(--slate);
      margin-top: 40px;
      margin-bottom: 14px;
      letter-spacing: -0.01em;
      scroll-margin-top: 24px;
    }
    article.content h3 {
      font-family: var(--serif);
      font-weight: 500;
      font-size: 19px;
      color: var(--slate);
      margin-top: 28px;
      margin-bottom: 10px;
      scroll-margin-top: 24px;
    }
    article.content h4 {
      font-family: var(--sans);
      font-weight: 600;
      font-size: 15px;
      color: var(--slate);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-top: 22px;
      margin-bottom: 8px;
    }
    article.content p {
      font-size: 15.5px;
      margin-bottom: 14px;
    }
    article.content p:first-of-type { margin-top: 0; }
    article.content ul,
    article.content ol {
      margin: 8px 0 18px 22px;
      font-size: 15px;
    }
    article.content ul li,
    article.content ol li {
      margin: 6px 0;
    }
    article.content a {
      color: var(--clay);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 2px;
    }
    article.content strong { color: var(--slate); font-weight: 600; }
    article.content em { font-style: italic; }
    article.content code {
      font-family: var(--mono);
      font-size: 13px;
      background: var(--gray-150);
      padding: 1px 6px;
      border-radius: 4px;
      color: var(--slate);
    }
    article.content pre {
      background: #0E0D0C;
      border: 1px solid var(--gray-300);
      border-radius: 10px;
      padding: 16px 18px;
      overflow-x: auto;
      margin: 14px 0 22px;
    }
    article.content pre code {
      background: transparent;
      color: #E8E6DE;
      font-size: 12.5px;
      line-height: 1.65;
      padding: 0;
      border-radius: 0;
    }
    article.content blockquote {
      border-left: 3px solid var(--oat);
      padding: 4px 0 4px 18px;
      margin: 14px 0;
      color: var(--gray-700);
      font-style: italic;
    }
    article.content hr {
      border: none;
      border-top: 1px solid var(--gray-300);
      margin: 32px 0;
    }
    article.content table {
      border-collapse: collapse;
      margin: 16px 0;
      font-size: 14px;
    }
    article.content th,
    article.content td {
      border-bottom: 1px solid var(--gray-300);
      padding: 8px 14px;
      text-align: left;
    }
    article.content th {
      font-family: var(--mono);
      font-size: 11.5px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--gray-500);
      font-weight: 600;
    }
  </style>
</head>
<body>
  <div class="page">

    <header class="page-head">
      <div class="eyebrow"><!-- TPL:EYEBROW --></div>
      <h1><!-- TPL:HEADING --></h1>
      <div class="doc-meta"><!-- TPL:META --></div>
    </header>

    <div class="layout">
      <main>
        <!-- TPL:TLDR_BLOCK -->
        <article class="content">
<!-- TPL:BODY -->
        </article>
      </main>

      <nav class="toc">
        <div class="t-head">In this doc</div>
        <!-- TPL:TOC -->
      </nav>
    </div>

  </div>
</body>
</html>
